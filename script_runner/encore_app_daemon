#!/system/bin/sh
# =============================================================================
#  ENCORE APP DAEMON — Game Focus Monitor
#  Activates DAVION ENGINE gaming mode when an Encore game enters foreground.
#  Reverts to normal mode when the game loses focus or exits.
#
#  Scope: GAME MODE ONLY — CPU profile, DND, saturation.
#  Per-app settings (brightness, RR, volume, conn, kill-others, cache)
#  are handled exclusively by per_app_daemon.
#
#  Reads: /data/adb/.config/encore/gamelist.json
# =============================================================================

MODDIR="/data/adb/modules/GovThermal"
LOG="/sdcard/GovThermal/GovThermal.log"
CFG_DIR="/sdcard/GovThermal/config"
ENCORE_GAMELIST="/data/adb/.config/encore/gamelist.json"
ENCORE_CFG="/data/adb/.config/encore/config.json"
DE_TOAST="$MODDIR/script_runner/de_toast"

# Script paths
GAMING_PROP="$MODDIR/DAVION_ENGINE/AI_MODE/gaming_mode/gaming_prop"
GAMING_CPUSET="$MODDIR/DAVION_ENGINE/AI_MODE/gaming_mode/gaming_cpuset"
LITE_GAMING="$MODDIR/DAVION_ENGINE/AI_MODE/gaming_mode/lite_gaming"
NORMAL_PROP="$MODDIR/DAVION_ENGINE/AI_MODE/normal_mode/normal_prop"
NORMAL_CPUSET="$MODDIR/DAVION_ENGINE/AI_MODE/normal_mode/normal_cpuset"

# State tracking
_active_pkg=""
_was_bg=""
_active_mode=""   # "gaming" | "lite" | ""
_dnd_active=0

log_msg() { echo "[$(date '+%H:%M:%S')] [ENCORE-DAEMON] $1" >> "$LOG"; }

# ── Toast notification ────────────────────────────────────────
de_notify() {
    local msg="$1" title="${2:-DAVION ENGINE}" type="${3:-info}"
    [ -x "$DE_TOAST" ] && "$DE_TOAST" "$msg" "$title" "$type" 2>/dev/null &
}

# ── Human-readable app label ──────────────────────────────────
get_app_label() {
    local pkg="$1" label
    label=$(pm dump "$pkg" 2>/dev/null \
        | grep -m1 "nonLocalizedLabel" \
        | sed 's/.*nonLocalizedLabel=//' \
        | tr -d '"' | tr -d '\r')
    [ -n "$label" ] && echo "$label" && return
    echo "$pkg"
}

# ── Gamelist helpers ──────────────────────────────────────────
gamelist_has_pkg() {
    local pkg="$1"
    [ -f "$ENCORE_GAMELIST" ] || return 1
    grep -q "\"$pkg\"" "$ENCORE_GAMELIST" 2>/dev/null
}

get_lite_mode() {
    local pkg="$1"
    [ -f "$ENCORE_GAMELIST" ] || { echo "false"; return; }
    local val
    val=$(awk -v p="\"$pkg\"" '
        $0 ~ p { found=1 }
        found && /lite_mode/ {
            match($0, /lite_mode.*:(true|false)/, a)
            if (a[1]) { print a[1]; exit }
        }
        found && /}/ { exit }
    ' "$ENCORE_GAMELIST" 2>/dev/null)
    echo "${val:-false}"
}

get_enable_dnd() {
    local pkg="$1"
    [ -f "$ENCORE_GAMELIST" ] || { echo "false"; return; }
    local val
    val=$(awk -v p="\"$pkg\"" '
        $0 ~ p { found=1 }
        found && /enable_dnd/ {
            match($0, /enable_dnd.*:(true|false)/, a)
            if (a[1]) { print a[1]; exit }
        }
        found && /}/ { exit }
    ' "$ENCORE_GAMELIST" 2>/dev/null)
    echo "${val:-false}"
}

get_global_enforce_lite() {
    [ -f "$ENCORE_CFG" ] || { echo "false"; return; }
    local val
    val=$(grep -o '"enforce_lite_mode"[[:space:]]*:[[:space:]]*[a-z]*' "$ENCORE_CFG" 2>/dev/null \
        | grep -o "true\|false" | head -1)
    echo "${val:-false}"
}

# ── DND ──────────────────────────────────────────────────────
enable_dnd() {
    cmd notification set-dnd on 2>/dev/null || \
    cmd notification set_ringer_mode 0 2>/dev/null || \
    settings put global zen_mode 1 2>/dev/null
    _dnd_active=1
    log_msg "  DND: enabled"
}

disable_dnd() {
    [ "$_dnd_active" -eq 1 ] || return
    cmd notification set-dnd off 2>/dev/null || \
    cmd notification set_ringer_mode 2 2>/dev/null || \
    settings put global zen_mode 0 2>/dev/null
    _dnd_active=0
    log_msg "  DND: disabled"
}

# ── Per-app saturation (game visual effect) ───────────────────
GLOBAL_SAT_FILE="/sdcard/DAVION_ENGINE_BoostColor/saturation_value"
RR_DIR="/sdcard/DAVION_ENGINE/refresh_locks"
_encore_last_sat_pkg=""

apply_per_app_saturation() {
    local pkg="$1"
    local sat_file="$RR_DIR/$pkg.sat"
    if [ -f "$sat_file" ]; then
        local sv
        sv=$(tr -d '[:space:]' < "$sat_file")
        if [ -n "$sv" ] && [ "$sv" -ge 0 ] 2>/dev/null && [ "$sv" -le 20 ] 2>/dev/null; then
            local sat_val
            sat_val=$(awk -v raw="$sv" 'BEGIN{printf "%.1f", raw / 10}')
            service call SurfaceFlinger 1022 f "$sat_val" >/dev/null 2>&1
            _encore_last_sat_pkg="$pkg"
            log_msg "  Saturation locked: ${sat_val}x for $pkg"
        fi
    fi
}

restore_saturation() {
    [ -z "$_encore_last_sat_pkg" ] && return
    if [ -f "$GLOBAL_SAT_FILE" ]; then
        local gs
        gs=$(tr -d '[:space:]' < "$GLOBAL_SAT_FILE")
        if [ -n "$gs" ]; then
            service call SurfaceFlinger 1022 f "$gs" >/dev/null 2>&1
            log_msg "  Saturation restored: ${gs}x (global)"
            _encore_last_sat_pkg=""
            return
        fi
    fi
    service call SurfaceFlinger 1022 f 1.0 >/dev/null 2>&1
    _encore_last_sat_pkg=""
}

# ── Get current foreground package ───────────────────────────
get_foreground_pkg() {
    local pkg
    pkg=$(dumpsys activity top 2>/dev/null \
        | grep -m1 "ACTIVITY" \
        | grep -oE "[a-z][a-zA-Z0-9_]*(\.[a-zA-Z0-9_]+)+" \
        | head -1)
    if [ -z "$pkg" ]; then
        local pid
        for p in /proc/[0-9]*/cpuset; do
            grep -q "top-app" "$p" 2>/dev/null || continue
            pid=$(echo "$p" | cut -d/ -f3)
            pkg=$(cat "/proc/$pid/cmdline" 2>/dev/null | tr '\0' '\n' | head -1)
            case "$pkg" in
                com.android.systemui|android|system_server|surfaceflinger)
                    pkg="" ; continue ;;
            esac
            [ -n "$pkg" ] && break
        done
    fi
    echo "$pkg"
}

# ── Activate gaming mode for a game ──────────────────────────
activate_tweaks() {
    local pkg="$1" lite_mode="$2" enable_dnd_val="$3"
    log_msg "Activating game mode: $pkg (lite=$lite_mode, dnd=$enable_dnd_val)"

    if [ "$lite_mode" = "true" ]; then
        [ -x "$LITE_GAMING" ] && sh "$LITE_GAMING" >/dev/null 2>&1 &
        _active_mode="lite"
        log_msg "  Mode: LITE GAMING"
    else
        [ -x "$GAMING_PROP" ]   && sh "$GAMING_PROP"   >/dev/null 2>&1
        [ -x "$GAMING_CPUSET" ] && sh "$GAMING_CPUSET" >/dev/null 2>&1
        _active_mode="gaming"
        log_msg "  Mode: GAMING"
    fi

    apply_per_app_saturation "$pkg"
    [ "$enable_dnd_val" = "true" ] && enable_dnd

    _active_pkg="$pkg"
    # Signal flag for other daemons (per_app, idle60, rr_guard, etc.)
    echo "$pkg" > /dev/.encore_tweaks_active 2>/dev/null

    local _label
    _label=$(get_app_label "$pkg")
    if [ "$lite_mode" = "true" ]; then
        de_notify "Lite Gaming Mode → ${_label}" "DAVION ENGINE" "info"
    else
        de_notify "Gaming Mode → ${_label}" "DAVION ENGINE" "success"
    fi
}

# ── Deactivate gaming mode, revert to normal ─────────────────
deactivate_tweaks() {
    local pkg="$1"
    log_msg "Deactivating game mode: $pkg"

    [ -x "$NORMAL_PROP" ]   && sh "$NORMAL_PROP"   >/dev/null 2>&1
    [ -x "$NORMAL_CPUSET" ] && sh "$NORMAL_CPUSET" >/dev/null 2>&1

    restore_saturation
    disable_dnd

    _active_pkg=""
    _active_mode=""
    rm -f /dev/.encore_tweaks_active 2>/dev/null
    log_msg "Normal mode restored"
    de_notify "Normal mode restored" "DAVION ENGINE" "info"
}

# ── Main monitor loop ─────────────────────────────────────────
log_msg "Started — monitoring foreground for Encore games"
FLAG_FILE="/dev/.encore_gamelist_updated"

while true; do

    # Skip if gamelist doesn't exist
    if [ ! -f "$ENCORE_GAMELIST" ]; then
        sleep 3
        continue
    fi

    # Live update: gamelist changed while running
    if [ -f "$FLAG_FILE" ]; then
        rm -f "$FLAG_FILE"
        if [ -n "$_active_pkg" ]; then
            if ! gamelist_has_pkg "$_active_pkg"; then
                deactivate_tweaks "$_active_pkg"
            else
                local_lite=$(get_lite_mode "$_active_pkg")
                global_lite=$(get_global_enforce_lite)
                [ "$global_lite" = "true" ] && local_lite="true"
                dnd_val=$(get_enable_dnd "$_active_pkg")
                deactivate_tweaks "$_active_pkg"
                activate_tweaks "$_active_pkg" "$local_lite" "$dnd_val"
            fi
        fi
    fi

    current_pkg=$(get_foreground_pkg)
    # Write shared foreground pkg for other daemons
    echo "$current_pkg" > /dev/.davion_last_fg_pkg 2>/dev/null

    # ── Detect if active game went to background ──────────────
    if [ -n "$_active_pkg" ] && [ "$current_pkg" != "$_active_pkg" ]; then
        _was_bg="$_active_pkg"
    fi

    # ── Game returned from background — re-apply ──────────────
    if [ -n "$_was_bg" ] && [ "$current_pkg" = "$_was_bg" ]; then
        log_msg "Game returned from bg: $current_pkg — re-applying"
        local_lite=$(get_lite_mode "$current_pkg")
        global_lite=$(get_global_enforce_lite)
        [ "$global_lite" = "true" ] && local_lite="true"
        dnd_val=$(get_enable_dnd "$current_pkg")
        [ -n "$_active_pkg" ] && deactivate_tweaks "$_active_pkg"
        activate_tweaks "$current_pkg" "$local_lite" "$dnd_val"
        _was_bg=""
        sleep 1
        continue
    fi

    # Nothing changed
    [ "$current_pkg" = "$_active_pkg" ] && { sleep 1; continue; }

    # ── Previous game lost focus ──────────────────────────────
    if [ -n "$_active_pkg" ] && [ "$_active_pkg" != "$current_pkg" ]; then
        deactivate_tweaks "$_active_pkg"
    fi

    # ── New foreground app — is it an Encore game? ────────────
    if [ -n "$current_pkg" ] && gamelist_has_pkg "$current_pkg"; then
        local_lite=$(get_lite_mode "$current_pkg")
        global_lite=$(get_global_enforce_lite)
        [ "$global_lite" = "true" ] && local_lite="true"
        dnd_val=$(get_enable_dnd "$current_pkg")
        activate_tweaks "$current_pkg" "$local_lite" "$dnd_val"
    fi

    sleep 1
done
