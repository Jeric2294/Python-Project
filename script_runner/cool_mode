#!/system/bin/sh
# =============================================================================
#  IMPROVED COOL MODE — Optimized for DAVION ENGINE
#  Target: Less Heating + No Framedrop (Balanced Performance)
#  Strategies: Smart Thermal + EEM Undervolt + Schedutil Gaming + CPUSet
#
#  Usage: cool_mode enable | disable
# =============================================================================

MODDIR="/data/adb/modules/GovThermal"
CFG_DIR="/sdcard/GovThermal/config"
LOG="$MODDIR/service.log"
COOL_STATE="$CFG_DIR/cool_mode_state"

ACTION="$1"

log_msg() { echo "[$(date '+%H:%M:%S')] [COOL_MODE] $1" >> "$LOG"; }

de_write() {
    local val="$1" path="$2"
    [ -f "$path" ] || return
    chmod 644 "$path" 2>/dev/null
    echo "$val" > "$path" 2>/dev/null
}

# ── 1. GPU Power Tuning (GED) ─────────────────────────────────
tune_gpu_power() {
    local enable="$1"
    if [ "$enable" = "1" ]; then
        # Reduce GPU boost aggressiveness but keep it responsive
        de_write 0 /sys/kernel/ged/hal/gpu_boost_level
        de_write 1 /sys/kernel/ged/hal/enable_gpu_boost
        # Reactive DVFS — responds to actual load
        de_write 0 /sys/kernel/ged/hal/dvfs_loading_mode
        # Reduce GED log overhead
        de_write 0 /sys/kernel/ged/hal/ged_log_buf_size_k
        log_msg "GPU: boost optimized, DVFS reactive mode"
    else
        # Restore GED defaults
        de_write 0 /sys/kernel/ged/hal/gpu_boost_level
        de_write 1 /sys/kernel/ged/hal/enable_gpu_boost
        de_write 1 /sys/kernel/ged/hal/dvfs_loading_mode
        log_msg "GPU: defaults restored"
    fi
}

# ── 2. EEM Extended Offsets (Undervolting) ───────────────────
tune_eem_gpu() {
    local val="$1"
    local cpuvolt_on=0
    [ "$(cat /sdcard/GovThermal/config/cpuvolt_enabled 2>/dev/null | tr -d '[:space:]')" = "1" ] && cpuvolt_on=1

    # GPU EEM offset
    de_write "$val" /proc/eemg/EEMG_DET_GPU/eemg_offset
    de_write "$val" /proc/eemg/EEMG_DET_GPU_HI/eemg_offset

    if [ "$cpuvolt_on" = "0" ]; then
        # Slightly more aggressive undervolt for better cooling
        de_write "$val" /proc/eem/EEM_DET_B/eem_offset
        de_write "$val" /proc/eem/EEM_DET_BL/eem_offset
        de_write "$val" /proc/eem/EEM_DET_L/eem_offset
        de_write "-6"   /proc/eem/EEM_DET_CCI/eem_offset
        log_msg "EEM: GPU+CPU offsets set to $val (CCI: -6)"
    else
        log_msg "EEM: GPU offset $val applied — CPU EEM skipped (CPU Volt Optimizer is ON)"
    fi
}

# ── 3. Schedutil Gaming Tuning ────────────────────────────────
tune_schedutil() {
    local enable="$1"
    for policy in /sys/devices/system/cpu/cpufreq/policy*; do
        [ -d "$policy" ] || continue
        local su_path="$policy/schedutil"
        local hz_path="$policy/schedhorizon"
        if [ "$enable" = "1" ]; then
            # Faster ramp-up (1000us) — ensures no frame drops when load spikes
            # Moderate ramp-down (8000us) — prevents freq jitter
            if [ -d "$hz_path" ]; then
                de_write 1000  "$hz_path/up_rate_limit_us"
                de_write 8000  "$hz_path/down_rate_limit_us"
            fi
            if [ -d "$su_path" ]; then
                de_write 1000  "$su_path/up_rate_limit_us"
                de_write 8000  "$su_path/down_rate_limit_us"
            fi
        else
            # Restore balanced defaults
            if [ -d "$hz_path" ]; then
                de_write 7500  "$hz_path/up_rate_limit_us"
                de_write 14000 "$hz_path/down_rate_limit_us"
            fi
            if [ -d "$su_path" ]; then
                de_write 7500  "$su_path/up_rate_limit_us"
                de_write 14000 "$su_path/down_rate_limit_us"
            fi
        fi
    done
    log_msg "Schedutil: $([ "$enable" = "1" ] && echo 'gaming-cool tuning' || echo 'defaults restored')"
}

# ── 4. DRAM/DVFSRC OPP Floor ─────────────────────────────────
tune_dram_opp() {
    local enable="$1"
    local found=0
    for base in "/sys/devices/platform/10012000.dvfsrc/helio-dvfsrc" "/sys/devices/platform/10042000.dvfsrc/helio-dvfsrc" "/sys/devices/platform/1c00f000.dvfsrc/mtk-dvfsrc-devfreq/devfreq/mtk-dvfsrc-devfreq"; do
        if [ -d "$base" ]; then
            found=1
            if [ "$enable" = "1" ]; then
                # Allow lowest DRAM OPP for cooling, but keep a reasonable floor for gaming
                de_write 0  "$base/dvfsrc_req_ddr_opp"
                de_write 0  /sys/kernel/helio-dvfsrc/dvfsrc_force_vcore_dvfs_opp
                log_msg "DRAM: OPP floor released for efficiency"
            else
                de_write -1 "$base/dvfsrc_req_ddr_opp"
                de_write -1 /sys/kernel/helio-dvfsrc/dvfsrc_force_vcore_dvfs_opp
                log_msg "DRAM: OPP restored to kernel-managed (-1)"
            fi
            break
        fi
    done
}

# ── 5. Smart Thermal Management (FPSGO) ──────────────────────
tune_smart_thermal() {
    local enable="$1"
    if [ "$enable" = "1" ]; then
        # Instead of disabling, set higher thresholds (90°C)
        # This prevents aggressive throttling while maintaining safety
        de_write 1 /sys/kernel/fpsgo/fbt/thrm_enable
        de_write 90 /sys/kernel/fpsgo/fbt/thrm_temp_th
        de_write 0 /sys/kernel/fpsgo/fbt/thrm_limit_cpu
        de_write 0 /sys/kernel/fpsgo/fbt/thrm_limit_fp
        
        # PPM Thermal Policy - Keep disabled for gaming as it's too aggressive
        if [ -d /proc/ppm ]; then
            for idx in $(grep -i "THERMAL" /proc/ppm/policy_status 2>/dev/null | grep -oE "[0-9]+" | tr -d "["); do
                de_write "$idx 0" /proc/ppm/policy_status
            done
        fi
        log_msg "Thermal: Smart thresholds applied (90°C)"
    else
        # Restore defaults
        de_write 1 /sys/kernel/fpsgo/fbt/thrm_enable
        de_write 75 /sys/kernel/fpsgo/fbt/thrm_temp_th
        if [ -d /proc/ppm ]; then
            for idx in $(grep -i "THERMAL" /proc/ppm/policy_status 2>/dev/null | grep -oE "[0-9]+" | tr -d "["); do
                de_write "$idx 1" /proc/ppm/policy_status
            done
        fi
        log_msg "Thermal: defaults restored"
    fi
}

# ── 6. CPUSet Optimization ───────────────────────────────────
tune_cpuset() {
    local enable="$1"
    if [ "$enable" = "1" ]; then
        # Move background tasks to little cores (0-3)
        # Keep big cores (4-7) for the game (top-app)
        echo 0-3 > /dev/cpuset/background/cpus 2>/dev/null
        echo 0-5 > /dev/cpuset/system-background/cpus 2>/dev/null
        echo 0-7 > /dev/cpuset/top-app/cpus 2>/dev/null
        log_msg "CPUSet: Background tasks restricted to little cores"
    else
        # Restore defaults (usually all cores)
        echo 0-7 > /dev/cpuset/background/cpus 2>/dev/null
        echo 0-7 > /dev/cpuset/system-background/cpus 2>/dev/null
        log_msg "CPUSet: defaults restored"
    fi
}

# ── 7. I/O and VM Optimization ───────────────────────────────
tune_io_vm() {
    local enable="$1"
    if [ "$enable" = "1" ]; then
        # Reduce background I/O interference
        echo 100 > /proc/sys/vm/vfs_cache_pressure
        echo 10 > /proc/sys/vm/dirty_ratio
        echo 3000 > /proc/sys/vm/dirty_expire_centisecs
        log_msg "I/O & VM: Optimized for gaming stability"
    else
        # Restore defaults
        echo 100 > /proc/sys/vm/vfs_cache_pressure
        echo 20 > /proc/sys/vm/dirty_ratio
        echo 3000 > /proc/sys/vm/dirty_expire_centisecs
        log_msg "I/O & VM: defaults restored"
    fi
}

# ── Enable Cool Mode ──────────────────────────────────────────
enable_cool() {
    log_msg "Enabling Improved Cool Mode..."
    tune_gpu_power 1
    tune_eem_gpu -10
    tune_schedutil 1
    tune_dram_opp 1
    tune_smart_thermal 1
    tune_cpuset 1
    tune_io_vm 1
    
    # Keep existing efficiency nodes
    de_write 1 /sys/kernel/ged/hal/dcs_mode
    de_write 1 /sys/power/mcdi_enable
    de_write 1 /sys/devices/system/cpu/cpuidle/cpuidle_sysfs_switch
    
    mkdir -p "$CFG_DIR"
    echo "enabled" > "$COOL_STATE"
    log_msg "Improved Cool Mode ENABLED ✓ (Less Heat + No Framedrop)"
}

# ── Disable Cool Mode ─────────────────────────────────────────
disable_cool() {
    log_msg "Disabling Improved Cool Mode..."
    tune_gpu_power 0
    tune_eem_gpu 0
    tune_schedutil 0
    tune_dram_opp 0
    tune_smart_thermal 0
    tune_cpuset 0
    tune_io_vm 0
    
    mkdir -p "$CFG_DIR"
    echo "disabled" > "$COOL_STATE"
    log_msg "Improved Cool Mode DISABLED ✓"
}

case "$ACTION" in
    enable)  enable_cool  ;;
    disable) disable_cool ;;
    *)
        echo "Usage: cool_mode [enable|disable]" >&2
        exit 1
        ;;
esac
