#!/system/bin/sh
# de_toast — system notification for DAVION ENGINE
# Usage: de_toast "Message" ["Title"] ["success|warn|error|info"]

MSG="${1:-DAVION ENGINE}"
TITLE="${2:-DAVION ENGINE}"
TYPE="${3:-info}"

case "$TYPE" in
    success) PREFIX="✅" ;;
    warn)    PREFIX="⚠️"  ;;
    error)   PREFIX="❌" ;;
    *)       PREFIX="🔔" ;;
esac

# Primary: termux-notification via am broadcast (Android 14 compatible)
am broadcast \
    -a com.termux.RUN_COMMAND \
    -n com.termux/.app.RunCommandService \
    --es com.termux.RUN_COMMAND_PATH '/data/data/com.termux/files/usr/bin/termux-notification' \
    --esa com.termux.RUN_COMMAND_ARGUMENTS "--title,$TITLE,--content,$PREFIX $MSG,--priority,high,--id,9101" \
    --ez com.termux.RUN_COMMAND_BACKGROUND true \
    2>/dev/null

# Fallback: cmd notification (Android 8-12)
if [ $? -ne 0 ]; then
    TAG="de_toast_$(date +%s%3N)"
    cmd notification post -S bigtext \
        -t "$TITLE" "$TAG" \
        "$PREFIX $MSG" 2>/dev/null
    (sleep 4 && cmd notification cancel "$TAG" 2>/dev/null) &
fi
