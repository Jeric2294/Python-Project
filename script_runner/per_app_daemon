#!/system/bin/sh
# =============================================================================
#  PER-APP DAEMON FIX v1.0
#  Comprehensive handler para sa:
#  ✅ Per-app volume application
#  ✅ Per-app refresh rate (mode) application  
#  ✅ Per-app spare 60Hz drop activation
#  ✅ Fallback sa universal settings
# =============================================================================

MODDIR="/data/adb/modules/GovThermal"
LOG="/sdcard/GovThermal/GovThermal.log"
CFG_DIR="/sdcard/GovThermal/config"
RR_DIR="/sdcard/DAVION_ENGINE/refresh_locks"
EXTERNAL_CFG="/sdcard/DAVION_ENGINE"

# Volume files
UNIV_VOL="$EXTERNAL_CFG/universal_vol.txt"

# Brightness files
UNIV_BRIGHT="$EXTERNAL_CFG/universal_brightness.txt"

# Refresh rate files
UNIV_RR="$EXTERNAL_CFG/universal_rr.txt"

# Spare 60Hz file
IDLE60_FLAG="$CFG_DIR/idle60_enabled"

# State tracking
LAST_FG_PKG=""
LAST_APPLIED_VOL=""
LAST_APPLIED_BRIGHT=""
LAST_APPLIED_MODE=""
LAST_APPLIED_SPARE=""

log_msg() { echo "[$(date '+%H:%M:%S')] [PER-APP-DAEMON] $1" >> "$LOG"; }

# ── VOLUME APPLICATION ───────────────────────────────────────────────────────
apply_volume() {
    local VOL="$1"
    [ -z "$VOL" ] && return 1
    
    # Try media_session first (more reliable)
    cmd media_session volume --stream 3 --set "$VOL" >/dev/null 2>&1 && return 0
    
    # Fallback to media command
    media volume --stream 3 --set "$VOL" >/dev/null 2>&1 && return 0
    
    return 1
}

# ── BRIGHTNESS APPLICATION ───────────────────────────────────────────────────
apply_brightness() {
    local BV="$1"
    [ -z "$BV" ] && return 1
    settings put system screen_brightness_mode 0 2>/dev/null
    settings put system screen_brightness "$BV" 2>/dev/null
    return $?
}

restore_brightness_to_auto_or_universal() {
    if [ -f "$UNIV_BRIGHT" ]; then
        local ub
        ub=$(tr -d '[:space:]' < "$UNIV_BRIGHT" 2>/dev/null)
        if [ -n "$ub" ] && [ "$ub" -ge 0 ] 2>/dev/null; then
            settings put system screen_brightness_mode 0 2>/dev/null
            settings put system screen_brightness "$ub" 2>/dev/null
            return 0
        fi
    fi
    # No universal brightness — restore auto
    settings put system screen_brightness_mode 1 2>/dev/null
    return 0
}

# ── REFRESH RATE APPLICATION ────────────────────────────────────────────────
apply_refresh_rate() {
    local MODE_ID="$1"
    [ -z "$MODE_ID" ] || [ "$MODE_ID" = "0" ] && return 1
    
    service call SurfaceFlinger 1035 i32 "$MODE_ID" >/dev/null 2>&1
    return $?
}

# ── GET CURRENT FOREGROUND PACKAGE ──────────────────────────────────────────
get_foreground_pkg() {
    local pkg=""
    
    # Try from /dev file first (fastest)
    if [ -f "/dev/.davion_last_fg_pkg" ]; then
        pkg=$(cat "/dev/.davion_last_fg_pkg" 2>/dev/null | tr -d '[:space:]')
        [ -n "$pkg" ] && echo "$pkg" && return 0
    fi
    
    # Fallback to dumpsys
    pkg=$(dumpsys activity top 2>/dev/null | \
        grep -m1 "ACTIVITY" | \
        grep -oE "[a-z][a-zA-Z0-9_]*(\.[a-zA-Z0-9_]+)+" | \
        head -1)
    [ -n "$pkg" ] && echo "$pkg" && return 0
    
    return 1
}

# ── GET PER-APP VOLUME ──────────────────────────────────────────────────────
get_app_volume() {
    local pkg="$1"
    [ -z "$pkg" ] && return 1
    
    local vol_file="$RR_DIR/${pkg}.vol"
    [ -f "$vol_file" ] || return 1
    
    local vol=$(tr -d '[:space:]' < "$vol_file" 2>/dev/null)
    if [ -n "$vol" ] && [ "$vol" -ge 0 ] 2>/dev/null && [ "$vol" -le 100 ] 2>/dev/null; then
        echo "$vol"
        return 0
    fi
    return 1
}

# ── GET UNIVERSAL VOLUME ────────────────────────────────────────────────────
get_universal_volume() {
    [ -f "$UNIV_VOL" ] || return 1
    
    local vol=$(tr -d '[:space:]' < "$UNIV_VOL" 2>/dev/null)
    if [ -n "$vol" ] && [ "$vol" -ge 0 ] 2>/dev/null && [ "$vol" -le 100 ] 2>/dev/null; then
        echo "$vol"
        return 0
    fi
    return 1
}

# ── GET PER-APP BRIGHTNESS ──────────────────────────────────────────────────
get_app_brightness() {
    local pkg="$1"
    [ -z "$pkg" ] && return 1
    
    local bright_file="$RR_DIR/${pkg}.bright"
    [ -f "$bright_file" ] || return 1
    
    local bv=$(tr -d '[:space:]' < "$bright_file" 2>/dev/null)
    if [ -n "$bv" ] && [ "$bv" -ge 0 ] 2>/dev/null; then
        echo "$bv"
        return 0
    fi
    return 1
}

# ── GET UNIVERSAL BRIGHTNESS ─────────────────────────────────────────────────
get_universal_brightness() {
    [ -f "$UNIV_BRIGHT" ] || return 1
    
    local bv=$(tr -d '[:space:]' < "$UNIV_BRIGHT" 2>/dev/null)
    if [ -n "$bv" ] && [ "$bv" -ge 0 ] 2>/dev/null; then
        echo "$bv"
        return 0
    fi
    return 1
}

# ── GET PER-APP REFRESH RATE ────────────────────────────────────────────────
get_app_refresh_rate() {
    local pkg="$1"
    [ -z "$pkg" ] && return 1
    
    local mode_file="$RR_DIR/${pkg}.mode"
    [ -f "$mode_file" ] || return 1
    
    local mode=$(tr -d '[:space:]' < "$mode_file" 2>/dev/null)
    if [ -n "$mode" ] && [ "$mode" != "0" ]; then
        echo "$mode"
        return 0
    fi
    return 1
}

# ── GET UNIVERSAL REFRESH RATE ──────────────────────────────────────────────
get_universal_refresh_rate() {
    [ -f "$UNIV_RR" ] || return 1
    
    local mode=$(tr -d '[:space:]' < "$UNIV_RR" 2>/dev/null)
    if [ -n "$mode" ] && [ "$mode" != "0" ]; then
        echo "$mode"
        return 0
    fi
    return 1
}

# ── CHECK IF APP HAS SPARE 60HZ ENABLED ─────────────────────────────────────
has_spare_60hz() {
    local pkg="$1"
    [ -z "$pkg" ] && return 1
    
    local spare_file="$RR_DIR/${pkg}.spare"
    [ -f "$spare_file" ] && return 0
    return 1
}

# ── APPLY PER-APP SETTINGS ──────────────────────────────────────────────────
apply_per_app_settings() {
    local pkg="$1"
    [ -z "$pkg" ] && return 1
    
    # ─────── VOLUME ─────────────────────────────────────────────────────────
    local vol=""
    local vol_source=""
    
    # PRIORITY: Per-app volume ALWAYS takes precedence
    if vol=$(get_app_volume "$pkg"); then
        vol_source="per-app"
    elif vol=$(get_universal_volume); then
        vol_source="universal"
    fi
    
    # Only apply if volume actually changed
    if [ -n "$vol" ] && [ "$vol" != "$LAST_APPLIED_VOL" ]; then
        if apply_volume "$vol"; then
            log_msg "📢 Volume applied: $vol ($vol_source) ← $pkg"
            LAST_APPLIED_VOL="$vol"
            # Mark that we applied per-app volume (for WebUI to check)
            if [ "$vol_source" = "per-app" ]; then
                touch "$RR_DIR/.vol_per_app_active" 2>/dev/null
            fi
        fi
    elif [ -z "$vol" ] && [ -n "$LAST_APPLIED_VOL" ]; then
        # No volume config for this app, clear the state
        LAST_APPLIED_VOL=""
        rm -f "$RR_DIR/.vol_per_app_active" 2>/dev/null
    fi

    # ─────── BRIGHTNESS ──────────────────────────────────────────────────────
    local bright=""
    local bright_source=""

    # PRIORITY: Per-app brightness takes precedence, then universal, then auto
    if bright=$(get_app_brightness "$pkg"); then
        bright_source="per-app"
    elif bright=$(get_universal_brightness); then
        bright_source="universal"
    fi

    if [ -n "$bright" ] && [ "$bright" != "$LAST_APPLIED_BRIGHT" ]; then
        if apply_brightness "$bright"; then
            log_msg "☀ Brightness applied: $bright ($bright_source) ← $pkg"
            LAST_APPLIED_BRIGHT="$bright"
        fi
    elif [ -z "$bright" ] && [ -n "$LAST_APPLIED_BRIGHT" ]; then
        # No brightness config for this app — restore universal or auto
        restore_brightness_to_auto_or_universal
        log_msg "☀ Brightness restored: auto/universal (no config for $pkg)"
        LAST_APPLIED_BRIGHT=""
    fi
    
    # ─────── REFRESH RATE ───────────────────────────────────────────────────
    local mode=""
    if mode=$(get_app_refresh_rate "$pkg"); then
        # Per-app refresh rate found
        if [ "$mode" != "$LAST_APPLIED_MODE" ]; then
            if apply_refresh_rate "$mode"; then
                log_msg "🎮 Refresh rate applied: mode $mode (per-app) ← $pkg"
                LAST_APPLIED_MODE="$mode"
            fi
        fi
    else
        # No per-app mode, try universal
        if mode=$(get_universal_refresh_rate); then
            if [ "$mode" != "$LAST_APPLIED_MODE" ]; then
                if apply_refresh_rate "$mode"; then
                    log_msg "🎮 Refresh rate applied: mode $mode (universal) ← $pkg"
                    LAST_APPLIED_MODE="$mode"
                fi
            fi
        fi
    fi
    
    # ─────── SPARE 60HZ DROP ────────────────────────────────────────────────
    # Check kung may spare 60Hz config para sa app na ito
    if has_spare_60hz "$pkg"; then
        # App has spare 60Hz enabled, activate idle60 para sa kanya
        if [ "$LAST_APPLIED_SPARE" != "$pkg" ]; then
            # Mark this app as having spare activated
            echo "$pkg" > "$EXTERNAL_CFG/spare_active_pkg.txt" 2>/dev/null
            log_msg "⚡ Spare 60Hz DROP activated for: $pkg"
            LAST_APPLIED_SPARE="$pkg"
            
            # Optional: Enable idle60 daemon if not running
            if [ -f "$IDLE60_FLAG" ] && [ "$(cat "$IDLE60_FLAG" 2>/dev/null | tr -d '[:space:]')" = "1" ]; then
                # Idle60 is enabled, it will handle this
                :
            fi
        fi
    else
        # App doesn't have spare, clear if this was the active one
        if [ "$LAST_APPLIED_SPARE" = "$pkg" ]; then
            rm -f "$EXTERNAL_CFG/spare_active_pkg.txt" 2>/dev/null
            log_msg "⚡ Spare 60Hz DROP deactivated (app $pkg has no .spare file)"
            LAST_APPLIED_SPARE=""
        fi
    fi
    
    # ─────── SAFETY CHECK: Re-apply per-app volume if it exists ───────────────
    # This prevents any other process from overriding per-app volume
    if [ -f "$RR_DIR/${pkg}.vol" ]; then
        local safety_vol=$(tr -d '[:space:]' < "$RR_DIR/${pkg}.vol" 2>/dev/null)
        if [ -n "$safety_vol" ] && [ "$safety_vol" -ge 0 ] 2>/dev/null && [ "$safety_vol" -le 100 ] 2>/dev/null; then
            # Get current system volume
            local current_vol=$(cmd media_session volume --stream 3 --get 2>/dev/null | grep -oE "[0-9]+" | tail -1 | tr -d '[:space:]')
            # If they don't match, re-apply the per-app volume
            if [ "$current_vol" != "$safety_vol" ]; then
                if apply_volume "$safety_vol"; then
                    log_msg "🔧 Safety reapply: per-app volume $safety_vol for $pkg (was $current_vol)"
                fi
            fi
        fi
    fi
}

# ── MAIN LOOP ───────────────────────────────────────────────────────────────
log_msg "Starting Per-App Daemon..."

# Set process priority
renice -n -15 -p $$ 2>/dev/null
echo $$ > /dev/cpuset/top-app/tasks 2>/dev/null
[ -f /proc/$$/oom_score_adj ] && echo -950 > /proc/$$/oom_score_adj 2>/dev/null

RAPID_POLL_COUNT=0  # Counter for rapid polling on app change

while true; do
    # Get current foreground package
    CURR_PKG=$(get_foreground_pkg)
    
    # If package changed or first run, apply settings IMMEDIATELY
    if [ -n "$CURR_PKG" ] && [ "$CURR_PKG" != "$LAST_FG_PKG" ]; then
        LAST_FG_PKG="$CURR_PKG"
        log_msg "App changed: $CURR_PKG"
        apply_per_app_settings "$CURR_PKG"
        # Reset LAST_APPLIED values to force re-apply on next poll if needed
        RAPID_POLL_COUNT=5  # Do 5 rapid re-checks (0.3s * 5 = 1.5s total)
    fi
    
    # Rapid re-polling right after app change to catch race conditions
    if [ "$RAPID_POLL_COUNT" -gt 0 ]; then
        sleep 0.15
        RAPID_POLL_COUNT=$((RAPID_POLL_COUNT - 1))
    else
        # Normal polling
        sleep 0.3
    fi

    # ── Brightness retrigger (signal from WebUI after saving per-app brightness) ──
    if [ -f "/dev/.davion_bright_retrigger" ]; then
        _trigger_pkg=$(tr -d '[:space:]' < "/dev/.davion_bright_retrigger" 2>/dev/null)
        rm -f "/dev/.davion_bright_retrigger" 2>/dev/null
        # Only act if the retrigger is for the current foreground app
        if [ -n "$_trigger_pkg" ] && [ "$_trigger_pkg" = "$LAST_FG_PKG" ]; then
            _new_bright=$(get_app_brightness "$_trigger_pkg")
            if [ -n "$_new_bright" ]; then
                if apply_brightness "$_new_bright"; then
                    log_msg "☀ Brightness retrigger: $_new_bright for $_trigger_pkg"
                    LAST_APPLIED_BRIGHT="$_new_bright"
                fi
            fi
        fi
        unset _trigger_pkg _new_bright
    fi
done
