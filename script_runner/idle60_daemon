#!/system/bin/sh
# =============================================================================
#  IDLE60 DAEMON — Auto 60Hz Drop on Touch Idle
#  Drops refresh rate to 60Hz when no touch is detected for N seconds.
#
#  Spare hierarchy (highest priority first):
#   1. Universal Spare toggle  → /sdcard/GovThermal/config/idle60_spare_universal
#   2. Per-app spare list      → /sdcard/DAVION_ENGINE/idle60_spare.txt
#   3. Per-app .spare flag     → /sdcard/DAVION_ENGINE/refresh_locks/<pkg>.spare
#   4. Per-app custom delay    → /sdcard/DAVION_ENGINE/idle60_delays.txt (pkg:seconds)
#
#  State files:
#   Enabled : /sdcard/GovThermal/config/idle60_enabled
#   Delay   : /sdcard/GovThermal/config/idle60_delay
# =============================================================================

MODDIR="/data/adb/modules/GovThermal"
LOG="/sdcard/GovThermal/GovThermal.log"
CFG_DIR="/sdcard/GovThermal/config"
DAVION_DIR="/sdcard/DAVION_ENGINE"

IDLE60_ENABLED_FILE="$CFG_DIR/idle60_enabled"
IDLE60_DELAY_FILE="$CFG_DIR/idle60_delay"
IDLE60_SPARE_FILE="$DAVION_DIR/idle60_spare.txt"
IDLE60_DELAYS_FILE="$DAVION_DIR/idle60_delays.txt"
UNIV_SPARE60_FILE="$CFG_DIR/idle60_spare_universal"
UNIVERSAL_RR_FILE="$DAVION_DIR/universal_rr.txt"
RR_DIR="$DAVION_DIR/refresh_locks"

TOUCH_FLAG="/dev/.davion_idle60_touch"

log_msg() { echo "[$(date '+%H:%M:%S')] [IDLE60] $1" >> "$LOG"; }

log_msg "Daemon started (PID $$)"

# ── Sanity: exit if idle60 is disabled ───────────────────────
_en=$(tr -d '[:space:]' < "$IDLE60_ENABLED_FILE" 2>/dev/null)
if [ "$_en" != "1" ]; then
    log_msg "idle60_enabled != 1 — exiting"
    exit 0
fi

# ── Get current foreground package ───────────────────────────
get_foreground_pkg() {
    local pkg
    pkg=$(dumpsys activity top 2>/dev/null \
        | grep -m1 "ACTIVITY" \
        | grep -oE "[a-z][a-zA-Z0-9_]*(\.[a-zA-Z0-9_]+)+" \
        | head -1)
    echo "$pkg"
}

# ── Per-app delay override ────────────────────────────────────
get_app_delay() {
    local pkg="$1"
    local default="$2"
    if [ -f "$IDLE60_DELAYS_FILE" ] && [ -n "$pkg" ]; then
        local line d
        line=$(grep "^${pkg}:" "$IDLE60_DELAYS_FILE" 2>/dev/null | head -1)
        if [ -n "$line" ]; then
            d=$(echo "$line" | cut -d: -f2 | tr -d '[:space:]')
            [ -n "$d" ] && echo "$d" && return
        fi
    fi
    echo "$default"
}

# ── Check if foreground app is individually spared ───────────
is_app_spared() {
    local pkg="$1"
    [ -z "$pkg" ] && return 1
    # Spare list (Panel 04 list)
    [ -f "$IDLE60_SPARE_FILE" ] && grep -qFx "$pkg" "$IDLE60_SPARE_FILE" 2>/dev/null && return 0
    # Per-app popup .spare flag
    [ -f "$RR_DIR/$pkg.spare" ] && return 0
    return 1
}

# ── Restore to universal RR ───────────────────────────────────
restore_rr() {
    local mode
    mode=$(tr -d '[:space:]' < "$UNIVERSAL_RR_FILE" 2>/dev/null)
    if [ -n "$mode" ] && [ "$mode" -eq "$mode" ] 2>/dev/null && [ "$mode" -gt 0 ]; then
        service call SurfaceFlinger 1035 i32 "$mode" >/dev/null 2>&1
        log_msg "RR restored: mode $mode"
    else
        service call SurfaceFlinger 1035 i32 0 >/dev/null 2>&1
        log_msg "RR restored: mode 0 (auto)"
    fi
}

# ── getevent touch watcher (background) ──────────────────────
# getevent -c 1 blocks until ONE input event fires, then exits.
# Loop forever: any input event (touch, button, sensor) = user activity.
# Rate-limit writes to once per second max to avoid hammering sdcard.
echo "$(date +%s)" > "$TOUCH_FLAG"

(
    _last_write=0
    while true; do
        getevent -c 1 >/dev/null 2>&1
        _now=$(date +%s)
        if [ $(( _now - _last_write )) -ge 1 ]; then
            echo "$_now" > "$TOUCH_FLAG"
            _last_write=$_now
        fi
    done
) &
_GE_PID=$!
log_msg "getevent watcher started (PID $_GE_PID)"

# ── Cleanup on exit ───────────────────────────────────────────
cleanup() {
    kill "$_GE_PID" 2>/dev/null
    # Kill any child getevent processes too
    pkill -f "getevent" 2>/dev/null
    log_msg "Daemon exiting"
    exit 0
}
trap cleanup INT TERM

# ── Main loop ─────────────────────────────────────────────────
DROPPED=0
_last_restore_reason=""

while true; do

    # Re-read enabled flag (WebUI may disable mid-run)
    _en=$(tr -d '[:space:]' < "$IDLE60_ENABLED_FILE" 2>/dev/null)
    if [ "$_en" != "1" ]; then
        if [ "$DROPPED" = "1" ]; then
            restore_rr
            DROPPED=0
        fi
        log_msg "Disabled via flag — exiting"
        cleanup
    fi

    # ── Priority 1: Universal Spare ON → never drop ───────────
    if [ -f "$UNIV_SPARE60_FILE" ]; then
        if [ "$DROPPED" = "1" ] && [ "$_last_restore_reason" != "univ_spare" ]; then
            restore_rr
            DROPPED=0
            _last_restore_reason="univ_spare"
            log_msg "Universal SPARE ON — restored from 60Hz drop"
        fi
        sleep 2
        continue
    fi

    # Read global delay
    DELAY=$(tr -d '[:space:]' < "$IDLE60_DELAY_FILE" 2>/dev/null)
    [ -z "$DELAY" ] && DELAY=5

    # ── Compute idle time ──────────────────────────────────────
    CUR_PKG=$(get_foreground_pkg)
    LAST=$(tr -d '[:space:]' < "$TOUCH_FLAG" 2>/dev/null)
    NOW=$(date +%s)
    [ -z "$LAST" ] && LAST="$NOW"
    IDLE=$((NOW - LAST))

    # Per-app delay override (custom delay per app still works)
    EFF_DELAY=$(get_app_delay "$CUR_PKG" "$DELAY")

    if [ "$IDLE" -ge "$EFF_DELAY" ] && [ "$DROPPED" = "0" ]; then
        # Idle threshold reached — drop to 60Hz
        service call SurfaceFlinger 1035 i32 0 >/dev/null 2>&1
        DROPPED=1
        _last_restore_reason=""
        log_msg "60Hz drop — idle=${IDLE}s delay=${EFF_DELAY}s app=$CUR_PKG"

    elif [ "$IDLE" -lt 2 ] && [ "$DROPPED" = "1" ]; then
        # Touch detected (idle < 2s) — restore
        restore_rr
        DROPPED=0
        _last_restore_reason="touch"
        log_msg "Touch — RR restored (idle was ${IDLE}s)"
    fi

    sleep 1
done
