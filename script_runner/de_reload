#!/system/bin/sh
# =============================================================================
#  DE_RELOAD — DAVION ENGINE Daemon Reloader
#  Called by action.sh after OTA fetch to apply new scripts without reboot.
#  Restarts: WebUI httpd, encore_app_daemon, idle60_daemon, rr_guard,
#            headset_daemon, otg_daemon, thermal_watchdog, hot_reload_daemon
# =============================================================================

MODID="GovThermal"
MODDIR="/data/adb/modules/$MODID"
LOG="/sdcard/GovThermal/GovThermal.log"
CFG_DIR="/sdcard/GovThermal/config"

log_msg() { echo "[$(date '+%H:%M:%S')] [DE_RELOAD] $1" >> "$LOG"; }

log_msg "=== OTA reload triggered ==="

# ── Fix permissions on freshly fetched files ──────────────────
find "$MODDIR/script_runner"    -type f -exec chmod 755 {} \; 2>/dev/null
find "$MODDIR/logcat_detection" -type f -exec chmod 755 {} \; 2>/dev/null
find "$MODDIR/webroot/cgi-bin"  -type f -exec chmod 755 {} \; 2>/dev/null
chmod 755 "$MODDIR/busybox" 2>/dev/null
log_msg "Permissions fixed"

# ── WebUI (httpd) ─────────────────────────────────────────────
pkill -f "busybox.*httpd.*8080" 2>/dev/null
pkill -f "httpd.*8080"          2>/dev/null
sleep 0.5
"$MODDIR/busybox" httpd -p 8080 \
    -h "$MODDIR/webroot/" \
    -c "$MODDIR/httpd.conf" \
    >> "$MODDIR/httpd.log" 2>&1 &
echo $! > "$MODDIR/httpd.pid"
log_msg "WebUI restarted (PID $!)"

# ── Encore App Daemon ─────────────────────────────────────────
pkill -f "encore_app_daemon" 2>/dev/null
sleep 0.3
ENCORE_DAEMON="$MODDIR/script_runner/encore_app_daemon"
if [ -x "$ENCORE_DAEMON" ]; then
    nohup sh "$ENCORE_DAEMON" >> "$LOG" 2>&1 &
    log_msg "encore_app_daemon restarted (PID $!)"
fi

# ── Auto 60Hz Drop (idle60_daemon) ────────────────────────────
pkill -f "idle60_daemon" 2>/dev/null
sleep 0.3
IDLE60_FLAG="$CFG_DIR/idle60_enabled"
IDLE60_DAEMON="$MODDIR/script_runner/idle60_daemon"
if [ -f "$IDLE60_FLAG" ] && [ "$(tr -d '[:space:]' < "$IDLE60_FLAG")" = "1" ]; then
    if [ -x "$IDLE60_DAEMON" ]; then
        nohup sh "$IDLE60_DAEMON" >> "$LOG" 2>&1 &
        log_msg "idle60_daemon restarted (PID $!)"
    fi
else
    log_msg "idle60_daemon skipped (disabled)"
fi

# ── RR Guard ─────────────────────────────────────────────────
pkill -f "rr_guard" 2>/dev/null
sleep 0.3
RR_GUARD_FLAG="$CFG_DIR/rr_guard_enabled"
RR_GUARD_DAEMON="$MODDIR/script_runner/rr_guard"
if [ -f "$RR_GUARD_FLAG" ] && [ "$(tr -d '[:space:]' < "$RR_GUARD_FLAG")" = "1" ]; then
    if [ -x "$RR_GUARD_DAEMON" ]; then
        nohup sh "$RR_GUARD_DAEMON" >> "$LOG" 2>&1 &
        log_msg "rr_guard restarted (PID $!)"
    fi
else
    log_msg "rr_guard skipped (disabled)"
fi

# ── Headset Daemon ────────────────────────────────────────────
pkill -f "headset_daemon" 2>/dev/null
sleep 0.3
HEADSET_VOL_FLAG="$CFG_DIR/headset_vol_on_connect"
HEADSET_MUTE_FLAG="$CFG_DIR/headset_mute_on_disconnect"
HEADSET_RESTORE_FLAG="$CFG_DIR/headset_restore_on_disconnect"
HEADSET_DAEMON="$MODDIR/script_runner/headset_daemon"
if [ -f "$HEADSET_VOL_FLAG" ] || [ -f "$HEADSET_MUTE_FLAG" ] || [ -f "$HEADSET_RESTORE_FLAG" ]; then
    if [ -x "$HEADSET_DAEMON" ]; then
        nohup sh "$HEADSET_DAEMON" >> "$LOG" 2>&1 &
        log_msg "headset_daemon restarted (PID $!)"
    fi
else
    log_msg "headset_daemon skipped (no flags set)"
fi

# ── OTG Daemon ────────────────────────────────────────────────
pkill -f "otg_daemon" 2>/dev/null
sleep 0.3
OTG_DAEMON="$MODDIR/script_runner/otg_daemon"
if [ -x "$OTG_DAEMON" ]; then
    nohup sh "$OTG_DAEMON" >> "$LOG" 2>&1 &
    log_msg "otg_daemon restarted (PID $!)"
fi

# ── Thermal Watchdog ─────────────────────────────────────────
pkill -f "thermal_watchdog" 2>/dev/null
sleep 0.3
THERMAL_STATE="$(tr -d '[:space:]' < "$CFG_DIR/thermal_state" 2>/dev/null)"
THERMAL_WATCHDOG="$MODDIR/script_runner/thermal_watchdog"
if [ "$THERMAL_STATE" = "disabled" ]; then
    if [ -x "$THERMAL_WATCHDOG" ]; then
        nohup sh "$THERMAL_WATCHDOG" >> "$LOG" 2>&1 &
        log_msg "thermal_watchdog restarted (PID $!)"
    fi
else
    log_msg "thermal_watchdog skipped (thermal not disabled)"
fi

# ── Hot Reload Daemon ─────────────────────────────────────────
pkill -f "hot_reload_daemon" 2>/dev/null
sleep 0.3
HOT_RELOAD="$MODDIR/script_runner/hot_reload_daemon"
if [ -x "$HOT_RELOAD" ]; then
    nohup sh "$HOT_RELOAD" >> "$LOG" 2>&1 &
    log_msg "hot_reload_daemon restarted (PID $!)"
fi

log_msg "=== OTA reload complete ==="
