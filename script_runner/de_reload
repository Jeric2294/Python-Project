#!/system/bin/sh
# =============================================================================
#  DE_RELOAD — Hot-apply all engine settings and restart all daemons
#  Used after OTA updates or manual changes to ensure effects are applied.
# =============================================================================

MODDIR="/data/adb/modules/GovThermal"
BB="$MODDIR/busybox"
LOG="$MODDIR/service.log"
CFG_DIR="/sdcard/GovThermal/config"
DE_ENGINE="$MODDIR/DAVION_ENGINE/AI_MODE/de_cpu_engine"
DE_TOAST="$MODDIR/script_runner/de_toast"

log_msg() { echo "[$(date '+%H:%M:%S')] [RELOAD] $1" >> "$LOG"; }
notify() { [ -x "$DE_TOAST" ] && "$DE_TOAST" "$1" "RELOAD" "$2" 2>/dev/null & }

log_msg "Starting full reload..."
notify "Applying changes..." "info"

# ── 1. Kill all background daemons ───────────────────────────
log_msg "Stopping daemons..."
pkill -f "encore_app_daemon" 2>/dev/null
pkill -f "GovThermal.*logcat" 2>/dev/null
pkill -f "GovThermal.*dumpsys2" 2>/dev/null
pkill -f "rr_guard" 2>/dev/null
pkill -f "idle60_daemon" 2>/dev/null
pkill -f "battery_guard" 2>/dev/null
pkill -f "headset_daemon" 2>/dev/null
pkill -f "otg_daemon" 2>/dev/null
pkill -f "thermal_watchdog" 2>/dev/null
pkill -f "ai_thermal_predict" 2>/dev/null
pkill -f "ai_adaptive_freq" 2>/dev/null
pkill -f "ai_app_classifier" 2>/dev/null
pkill -f "hot_reload_daemon" 2>/dev/null
# Note: httpd is usually handled separately or restarted if webroot changed, 
# but we can restart it here too for a "full" reload.
pkill -f "httpd.*8080" 2>/dev/null

# ── 2. Re-apply Engine Settings ──────────────────────────────
if [ -f "$DE_ENGINE" ]; then
    chmod 755 "$DE_ENGINE" 2>/dev/null
    . "$DE_ENGINE"
    
    SAVED_PROFILE=$(tr -d '[:space:]' < "$CFG_DIR/active_profile" 2>/dev/null)
    [ -z "$SAVED_PROFILE" ] && SAVED_PROFILE="balanced"
    
    case "$SAVED_PROFILE" in
        performance) de_performance_cpu; log_msg "Applied: Performance profile" ;;
        powersave)   de_powersave_cpu;   log_msg "Applied: Powersave profile"   ;;
        *)           de_balanced_cpu;    log_msg "Applied: Balanced profile"    ;;
    esac
fi

# ── 3. Re-apply Thermal State ────────────────────────────────
THERMAL_SCRIPT="$MODDIR/script_runner/thermal_toggle"
THERMAL_STATE=$(tr -d '[:space:]' < "$CFG_DIR/thermal_state" 2>/dev/null)
if [ "$THERMAL_STATE" = "disabled" ]; then
    sh "$THERMAL_SCRIPT" disable 2>/dev/null
    log_msg "Applied: Thermal disabled"
else
    sh "$THERMAL_SCRIPT" enable 2>/dev/null
    log_msg "Applied: Thermal enabled"
fi

# ── 4. Re-apply SurfaceFlinger & Display ─────────────────────
# (Simplified version of service.sh logic)
SAT_FILE="/sdcard/DAVION_ENGINE_BoostColor/saturation_value"
[ -f "$SAT_FILE" ] && SAT_VAL=$(tr -d '[:space:]' < "$SAT_FILE") && \
    service call SurfaceFlinger 1022 f "$SAT_VAL" >/dev/null 2>&1

# ── 5. Restart all daemons ───────────────────────────────────
log_msg "Restarting daemons..."
nohup sh "$MODDIR/script_runner/encore_app_daemon" >> "$LOG" 2>&1 &
nohup sh "$MODDIR/logcat_detection/logcat" >> "$LOG" 2>&1 &
nohup sh "$MODDIR/script_runner/rr_guard" >> "$LOG" 2>&1 &
nohup sh "$MODDIR/script_runner/idle60_daemon" >> "$LOG" 2>&1 &
nohup sh "$MODDIR/script_runner/battery_guard" >> "$LOG" 2>&1 &
nohup sh "$MODDIR/script_runner/headset_daemon" >> "$LOG" 2>&1 &
nohup sh "$MODDIR/script_runner/otg_daemon" >> "$LOG" 2>&1 &
nohup sh "$MODDIR/script_runner/thermal_watchdog" >> "$LOG" 2>&1 &
nohup sh "$MODDIR/script_runner/ai_thermal_predict" >> "$LOG" 2>&1 &
nohup sh "$MODDIR/script_runner/ai_adaptive_freq" >> "$LOG" 2>&1 &
nohup sh "$MODDIR/script_runner/ai_app_classifier" >> "$LOG" 2>&1 &
nohup sh "$MODDIR/script_runner/hot_reload_daemon" >> "$LOG" 2>&1 &

# Restart WebUI
"$BB" httpd -p 8080 -h "$MODDIR/webroot" -c "$MODDIR/httpd.conf" >> "$LOG" 2>&1 &

log_msg "Full reload complete."
notify "Changes applied successfully!" "success"
