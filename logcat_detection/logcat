# Volume apply helper (media_session preferred, fallback to media)
apply_volume() {
    local VOL="$1"
    cmd media_session volume --stream 3 --set "$VOL" >/dev/null 2>&1
    media volume --stream 3 --set "$VOL" >/dev/null 2>&1
}

# --- CONN LAUNCH SMART SWITCH ---
# Enables the required connection for a new app and disables the old one
# if the previous app was using a different type (wifi→data or data→wifi).
apply_conn_launch() {
    local pkg="$1"
    local new_conn="$2"
    local prev_conn=""
    [ -f "$_CL_LAST_CONN" ] && prev_conn=$(tr -d '[:space:]' < "$_CL_LAST_CONN" 2>/dev/null)

    # Cancel any pending idle WiFi-off timer
    if [ -f "$_CL_IDLE_PID" ]; then
        local _idle_pid
        _idle_pid=$(tr -d '[:space:]' < "$_CL_IDLE_PID" 2>/dev/null)
        [ -n "$_idle_pid" ] && kill "$_idle_pid" 2>/dev/null
        rm -f "$_CL_IDLE_PID"
    fi

    # Read actual current connection states
    local _wifi_on _data_on _raw
    _raw=$(settings get global wifi_on 2>/dev/null | tr -d '[:space:]')
    case "$_raw" in
        1) _wifi_on="1" ;;
        0) _wifi_on="0" ;;
        *) _wifi_on=$(dumpsys wifi 2>/dev/null | grep -c "Wi-Fi is enabled" | tr -d '[:space:]'); [ "$_wifi_on" = "1" ] || _wifi_on="0" ;;
    esac
    _raw=$(settings get global mobile_data 2>/dev/null | tr -d '[:space:]')
    case "$_raw" in
        1) _data_on="1" ;;
        *) _data_on="0" ;;
    esac

    case "$new_conn" in
        wifi)
            # Only enable WiFi if it's actually off
            if [ "$_wifi_on" != "1" ]; then
                svc wifi enable 2>/dev/null
                log_msg "📶 WiFi enabled → $pkg"
            else
                log_msg "📶 WiFi already on → $pkg (no change)"
            fi
            # Only disable data if it was the previous conn type (avoid disrupting unrelated data)
            if [ "$prev_conn" = "data" ] || [ "$prev_conn" = "both" ]; then
                svc data disable 2>/dev/null
                log_msg "📶 Data off (prev=$prev_conn) → $pkg"
            fi
            ;;
        data)
            # Only enable data if it's actually off
            if [ "$_data_on" != "1" ]; then
                svc data enable 2>/dev/null
                log_msg "📡 Data enabled → $pkg"
            else
                log_msg "📡 Data already on → $pkg (no change)"
            fi
            # Only disable WiFi if it was the previous conn type
            if [ "$prev_conn" = "wifi" ] || [ "$prev_conn" = "both" ]; then
                svc wifi disable 2>/dev/null
                log_msg "📡 WiFi off (prev=$prev_conn) → $pkg"
            fi
            ;;
        both)
            # Only enable what's not already on
            [ "$_wifi_on" != "1" ] && svc wifi enable 2>/dev/null && log_msg "⚡ WiFi enabled → $pkg"
            [ "$_data_on" != "1" ] && svc data enable 2>/dev/null && log_msg "⚡ Data enabled → $pkg"
            if [ "$_wifi_on" = "1" ] && [ "$_data_on" = "1" ]; then
                log_msg "⚡ WiFi+Data already on → $pkg (no change)"
            fi
            ;;
    esac
    echo "$new_conn" > "$_CL_LAST_CONN" 2>/dev/null
}

# Start the idle conn-off 20s timer — turns off whatever conn was last enabled
# Fires for wifi, data, or both. Cancels if a configured app launches within 20s.
start_idle_conn_timer() {
    [ -f "$CONN_IDLE_WIFI_OFF_FILE" ] || return
    local last_conn=""
    [ -f "$_CL_LAST_CONN" ] && last_conn=$(tr -d '[:space:]' < "$_CL_LAST_CONN" 2>/dev/null)
    # Only start if there was a previously active conn to clean up
    case "$last_conn" in
        wifi|data|both) ;;
        *) return ;;
    esac

    # Kill any previous timer
    if [ -f "$_CL_IDLE_PID" ]; then
        local _p
        _p=$(tr -d '[:space:]' < "$_CL_IDLE_PID" 2>/dev/null)
        [ -n "$_p" ] && kill "$_p" 2>/dev/null
        rm -f "$_CL_IDLE_PID"
    fi

    local _snap_conn="$last_conn"
    (
        sleep 20
        # Check what's in foreground now
        curr_fg=$(tr -d '[:space:]' < /dev/.davion_last_fg_pkg 2>/dev/null)
        # If a configured conn app is active — do not turn off
        curr_conn_file="$REFRESH_LOCK_DIR/${curr_fg}.conn"
        curr_legacy_file="$REFRESH_LOCK_DIR/${curr_fg}.wifi"
        if [ -f "$curr_conn_file" ] || [ -f "$curr_legacy_file" ]; then
            rm -f "$_CL_IDLE_PID"
            return
        fi
        # If a real user app (not launcher/recents/systemui) is foreground — do not turn off
        case "$curr_fg" in
            *launcher*|*systemui*|*recents*|*recenttasks*|*overview*|*nexuslauncher*|\
            *trebuchet*|*lawnchair*|*home*|android|"")
                # User is idle / on home / recents — safe to turn off
                ;;
            *)
                # Some other app is in foreground — cancel
                rm -f "$_CL_IDLE_PID"
                return
                ;;
        esac
        # Turn off whatever was last enabled
        case "$_snap_conn" in
            wifi)
                svc wifi disable 2>/dev/null
                log_msg "📶 WiFi auto-off after 20s (idle/recents)"
                ;;
            data)
                svc data disable 2>/dev/null
                log_msg "📡 Data auto-off after 20s (idle/recents)"
                ;;
            both)
                svc wifi disable 2>/dev/null
                svc data disable 2>/dev/null
                log_msg "⚡ WiFi+Data auto-off after 20s (idle/recents)"
                ;;
        esac
        echo "" > "$_CL_LAST_CONN" 2>/dev/null
        rm -f "$_CL_IDLE_PID"
    ) &
    echo $! > "$_CL_IDLE_PID"
    log_msg "⏱️ Idle conn-off timer started (20s) — last: $_snap_conn"
}

# --- KILL OTHERS ON LAUNCH ---
apply_killothers() {
    local TARGET_PKG="$1"
    local BL_FILE="$REFRESH_LOCK_DIR/${TARGET_PKG}.killothers_bl"
    local TMP_FILE="/data/local/tmp/davion_killed_$(echo "$TARGET_PKG" | tr '.' '_').tmp"
    rm -f "$TMP_FILE"
    (
        pm list packages -3 2>/dev/null | cut -d: -f2 | while read -r pkg; do
            [ -z "$pkg" ] && continue
            [ "$pkg" = "$TARGET_PKG" ] && continue
            case "$pkg" in
                io.github.kernelsu*|me.bmax.apatch*|com.topjohnwu.magisk*) continue ;;
            esac
            if [ -f "$BL_FILE" ] && grep -qxF "$pkg" "$BL_FILE" 2>/dev/null; then
                continue
            fi
            _pre_pid=$(pidof "$pkg" 2>/dev/null)
            am force-stop "$pkg" 2>/dev/null
            [ -n "$_pre_pid" ] && echo "$pkg" | awk -F. '{print $NF}' >> "$TMP_FILE"
        done

        KILLED_COUNT=0
        KILLED_NAMES=""
        if [ -f "$TMP_FILE" ]; then
            while read -r n; do
                [ -z "$n" ] && continue
                KILLED_COUNT=$((KILLED_COUNT + 1))
                if [ -z "$KILLED_NAMES" ]; then
                    KILLED_NAMES="$n"
                else
                    KILLED_NAMES="$KILLED_NAMES, $n"
                fi
            done < "$TMP_FILE"
            rm -f "$TMP_FILE"
        fi
        log_msg "Kill Others: stopped $KILLED_COUNT app(s) for $TARGET_PKG"
        if [ "$KILLED_COUNT" -gt 0 ]; then
            TARGET_SHORT=$(echo "$TARGET_PKG" | awk -F. '{print $NF}' | \
                awk '{print toupper(substr($0,1,1)) substr($0,2)}')
            # Capitalize first letter of each app name
            KILLED_NAMES_CAP=$(echo "$KILLED_NAMES" | \
                awk '{
                    n = split($0, a, ", ")
                    out = ""
                    for (i=1; i<=n; i++) {
                        word = a[i]
                        first = substr(word,1,1)
                        rest  = substr(word,2)
                        cap   = toupper(first) rest
                        if (i==1) out = cap
                        else out = out "  •  " cap
                    }
                    print out
                }')
            DIVIDER="━━━━━━━━━━━━━━━━━━━━━━━━"
            MSG="${DIVIDER}
⚔  ${KILLED_COUNT} App(s) Terminated
${DIVIDER}
${KILLED_NAMES_CAP}
${DIVIDER}
▸ DAVION°ENGINE · Kill Others"
            su -lp 2000 -c "cmd notification post -S bigtext -t '🗡️ Killer / Suspect — ${TARGET_SHORT}' tag '${MSG}'" >/dev/null 2>&1
        fi
    ) &
}

